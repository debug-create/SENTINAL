# ── REQUIRED: Groq Cloud API Key ─────────────────────────────────────────
# Get one for free from https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here

# ── REQUIRED FOR PRODUCTION DEPLOYMENT ──────────────────────────────────
# Do NOT deploy with blank or default values for security.
# API_KEY secures normal user-facing endpoints.
API_KEY=your-secure-user-api-key-here
# ADMIN_TOKEN secures supervisor queue, promoter, and KB audit endpoints.
ADMIN_TOKEN=your-secure-admin-token-here

# ── Storage Configuration ──────────────────────────────────────────────
# Storage directory for persistent disk mount in production (e.g. Render/Vercel)
STORAGE_DIR=./storage
# Individual overrides (optional, default to subpaths of STORAGE_DIR)
# CHROMA_PATH=
# PENDING_FILE=
# QUEUE_FILE=
# TRACKER_FILE=
# FINDINGS_FILE=

# ── Networking ─────────────────────────────────────────────────────────
# Server port for FastAPI (default: 8000)
PORT=8000
# Commas-separated list of allowed origins.
# IMPORTANT: In production, change this to your Vercel/frontend app URL!
CORS_ORIGINS=http://localhost:5173

# ── Supervisor Configuration ───────────────────────────────────────────
# If true, synthesized FAQs require admin approval before writing to ChromaDB.
REQUIRE_APPROVAL=true
