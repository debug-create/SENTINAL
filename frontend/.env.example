# ── Frontend Environment Configuration ──────────────────────────────────
# In production, set these variables to point to your deployed backend.

# Client API key used to authenticate requests against normal backend endpoints.
# MUST match the API_KEY value set in your backend configuration.
VITE_API_KEY=your-secure-user-api-key-here

# WebSocket backend URL (e.g. wss://sentinel-backend.onrender.com in production)
VITE_WS_URL=ws://localhost:8000

# REST backend URL (e.g. https://sentinel-backend.onrender.com in production)
VITE_API_URL=http://localhost:8000
