# ============================================================
# 3. BACKEND RULES
# ============================================================

# RAG thresholds (defined in rag.py — do NOT change these values arbitrarily):
#   CONFIDENCE_THRESHOLD = 0.75   → below this triggers the clarification loop
#   DUPLICATE_THRESHOLD  = 0.88   → above this blocks new KB entry (dupe detected)

# Similarity formula (ChromaDB returns cosine distance in [0,2]):
#   similarity = 1 - (distance / 2)

# All ChromaDB + Groq SDK calls are SYNCHRONOUS — always wrap in:
#   await loop.run_in_executor(None, blocking_fn)
# NEVER call them directly in async FastAPI handlers. This will block the event loop.

# WebSocket message schema (backend → frontend), always JSON:
#   { "type": "confidence",          "source": "known"|"synthesized", "score": float }
#   { "type": "token",               "token": str }
#   { "type": "done" }
#   { "type": "clarifying_question", "question": str }
#   { "type": "kb_updated",          "entry": { "question": str, "answer": str } }
#   { "type": "kb_duplicate" }
#   { "type": "error",               "message": str }

# WebSocket message schema (frontend → backend), always JSON:
#   { "type": "user_msg",      "message": str }
#   { "type": "clarification", "message": str }

# Session state: main.py maintains a dict:
#   pending_synthesis = { session_id: { "query": str, "context": str } }
# This persists the original query across the clarification round-trip.

# REST endpoints:
#   GET /api/kb           → returns full KB as JSON array
#   GET /knowledge-base   → alias for the above (used by frontend polling)

# ChromaDB storage: ./chroma_db (PersistentClient — survives restarts)
# Collection name: sentinel_kb
# Distance metric: cosine (hnsw:space: cosine)

# ============================================================
# 4. FRONTEND RULES
# ============================================================

# WebSocket URL: ws://localhost:8000/ws/{sessionId}
#   sessionId = crypto.randomUUID() on mount, stored in useRef (not state)
#   Reconnect interval: 3 seconds on disconnect

# State that lives in App.jsx (pass down as props — do NOT lift to context):
#   analytics: { questionsAsked, answeredFromKB, synthesized, avgConfidence }
#   kbRefreshTrigger: int (increment to force KBPanel to re-fetch)
#   newEntry: object | null (latest synthesized entry for glow animation)

# State that lives in ChatPanel.jsx:
#   messages: array of message objects
#   awaitingClarification: bool
#     → true  = send { type: "clarification" }, input placeholder = "Answer the question above..."
#     → false = send { type: "user_msg" }, normal placeholder
#   isConnected: bool
#   currentStreamingId: string | null (ID of message currently receiving tokens)

# Message object shape:
#   { id, type, content, confidence?, source?, isStreaming? }
#   type values: "greeting" | "user" | "bot" | "clarifying" | "kb_update" | "error"

# KBPanel polling: GET /knowledge-base every 5 seconds (setInterval in useEffect)
# New entry animation: CSS class "entry-new" → amber glow for 4s then fades
#   Applied when newEntry prop changes, removed after 4000ms via setTimeout

